	"info": {
		"title": "Movies App API",
		"description": "REST API for Movies application\n\n**Links:**\n- [OpenAPI JSON](/api/docs/json)\n- [OpenAPI YAML](/api/docs/yaml)",
		"version": "1.0.0",
		"contact": {}
	},
	"tags": [],
	"servers": [{ "url": "http://localhost:8080" }],
	"components": {
		"securitySchemes": {
			"access-token": {
				"scheme": "bearer",
				"bearerFormat": "JWT",
				"type": "http",
				"description": "Enter JWT access token"
			}
		},
		"schemas": {
			"HealthResponseDto": {
				"type": "object",
				"properties": {
					"status": { "type": "string", "enum": ["ok", "degraded"] },
					"timestamp": { "type": "number" },
					"database": { "type": "string", "enum": ["connected", "disconnected"] },
					"error": { "type": "string" }
				},
				"required": ["status", "timestamp", "database"]
			},
			"UserCreateDto": {
				"type": "object",
				"properties": {
					"name": { "type": "string", "example": "John Doe" },
					"email": { "type": "string", "example": "john@example.com" },
					"password": { "type": "string", "example": "SecurePass123!" }
				},
				"required": ["name", "email", "password"]
			},
			"UserResponseDto": {
				"type": "object",
				"properties": {
					"id": { "type": "number" },
					"name": { "type": "string" },
					"email": { "type": "string" },
					"role": { "type": "string" },
					"createdAt": { "format": "date-time", "type": "string" },
					"updatedAt": { "format": "date-time", "type": "string" }
				},
				"required": ["id", "name", "email", "role", "createdAt", "updatedAt"]
			},
			"UserUpdateDto": {
				"type": "object",
				"properties": {
					"name": { "type": "string", "example": "John Doe" },
					"email": { "type": "string", "example": "john@example.com" },
					"password": { "type": "string", "example": "NewSecurePass123!" }
				}
			},
			"AuthRegisterDto": {
				"type": "object",
				"properties": {
					"name": { "type": "string", "example": "John Doe" },
					"email": { "type": "string", "example": "john@example.com" },
					"password": { "type": "string", "example": "SecurePass123!" }
				},
				"required": ["name", "email", "password"]
			},
			"AuthResponseDto": {
				"type": "object",
				"properties": { "accessToken": { "type": "string" } },
				"required": ["accessToken"]
			},
			"AuthLoginDto": {
				"type": "object",
				"properties": {
					"email": { "type": "string", "example": "john@example.com" },
					"password": { "type": "string", "example": "SecurePass123!" }
				},
				"required": ["email", "password"]
			},
			"CsrfResponseDto": {
				"type": "object",
				"properties": { "token": { "type": "string" } },
				"required": ["token"]
			},
			"ProviderMovieSummary": {
				"type": "object",
				"properties": {
					"imdbId": { "type": "string", "nullable": true },
					"externalId": { "type": "string" },
					"title": { "type": "string" },
					"posterPath": { "type": "string", "nullable": true },
					"overview": { "type": "string" },
					"releaseYear": { "type": "number", "nullable": true },
					"rating": { "type": "number" }
				},
				"required": [
					"imdbId",
					"externalId",
					"title",
					"posterPath",
					"overview",
					"releaseYear",
					"rating"
				]
			},
			"ProviderSearchResult": {
				"type": "object",
				"properties": {
					"page": { "type": "number" },
					"totalPages": { "type": "number" },
					"totalResults": { "type": "number" },
					"results": {
						"type": "array",
						"items": { "$ref": "#/components/schemas/ProviderMovieSummary" }
					}
				},
				"required": ["page", "totalPages", "totalResults", "results"]
			},
			"MovieResponseDto": {
				"type": "object",
				"properties": {
					"id": { "type": "number" },
					"externalId": { "type": "string" },
					"imdbId": { "type": "string", "nullable": true },
					"title": { "type": "string" },
					"posterPath": { "type": "string", "nullable": true },
					"overview": { "type": "string", "nullable": true },
					"releaseYear": { "type": "number", "nullable": true },
					"rating": { "type": "string", "nullable": true },
					"genres": { "nullable": true, "type": "array", "items": { "type": "string" } },
					"runtime": { "type": "number", "nullable": true },
					"createdAt": { "format": "date-time", "type": "string" },
					"updatedAt": { "format": "date-time", "type": "string" }
				},
				"required": [
					"id",
					"externalId",
					"imdbId",
					"title",
					"posterPath",
					"overview",
					"releaseYear",
					"rating",
					"genres",
					"runtime",
					"createdAt",
					"updatedAt"
				]
			},
			"MovieCreateDto": {
				"type": "object",
				"properties": {
					"imdbId": {
						"type": "string",
						"description": "IMDb ID (universal)",
						"example": "tt0133093"
					},
					"externalId": {
						"type": "string",
						"description": "Provider external ID",
						"example": "301"
					}
				}
			},
			"MovieUpdateDto": {
				"type": "object",
				"properties": {
					"title": { "type": "string", "description": "Movie title" },
					"posterPath": { "type": "string", "description": "Poster path" },
					"overview": { "type": "string", "description": "Movie overview" },
					"releaseYear": { "type": "number", "description": "Release year", "example": 1999 },
					"rating": {
						"type": "number",
						"description": "Rating (0-10)",
						"minimum": 0,
						"maximum": 10
					},
					"runtime": { "type": "number", "description": "Runtime in minutes" }
				}
			},
			"GroupResponseDto": {
				"type": "object",
				"properties": {
					"id": { "type": "number" },
					"name": { "type": "string" },
					"description": { "type": "string", "nullable": true },
					"avatarUrl": { "type": "string", "nullable": true },
					"createdAt": { "format": "date-time", "type": "string" },
					"updatedAt": { "format": "date-time", "type": "string" }
				},
				"required": ["id", "name", "description", "avatarUrl", "createdAt", "updatedAt"]
			},
			"GroupCreateDto": {
				"type": "object",
				"properties": {
					"name": { "type": "string", "example": "Movie Club", "description": "Group name" },
					"description": {
						"type": "string",
						"example": "Weekly movie nights",
						"description": "Group description"
					},
					"avatarUrl": {
						"type": "string",
						"example": "https://example.com/avatar.jpg",
						"description": "Group avatar URL"
					}
				},
				"required": ["name"]
			},
			"GroupUpdateDto": {
				"type": "object",
				"properties": {
					"name": { "type": "string", "example": "Movie Club" },
					"description": { "type": "string", "example": "Weekly movie nights" },
					"avatarUrl": { "type": "string", "example": "https://example.com/avatar.jpg" }
				}
			},
			"GroupMemberResponseDto": {
				"type": "object",
				"properties": {
					"id": { "type": "number" },
					"groupId": { "type": "number" },
					"userId": { "type": "number" },
					"role": { "type": "string", "enum": ["admin", "moderator", "member"] },
					"createdAt": { "format": "date-time", "type": "string" },
					"updatedAt": { "format": "date-time", "type": "string" },
					"user": { "type": "object" }
				},
				"required": ["id", "groupId", "userId", "role", "createdAt", "updatedAt"]
			},
			"GroupMemberAddDto": {
				"type": "object",
				"properties": {
					"userId": {
						"type": "number",
						"example": 1,
						"description": "User ID to add to the group"
					},
					"role": {
						"type": "string",
						"example": "member",
						"description": "Role in the group",
						"enum": ["admin", "moderator", "member"]
					}
				},
				"required": ["userId"]
			},
			"GroupMemberRoleUpdateDto": {
				"type": "object",
				"properties": {
					"role": {
						"type": "string",
						"example": "moderator",
						"description": "New role for the member",
						"enum": ["admin", "moderator", "member"]
					}
				},
				"required": ["role"]
			},
			"TransferOwnershipDto": {
				"type": "object",
				"properties": {
					"targetUserId": {
						"type": "number",
						"example": 123,
						"description": "User ID to transfer admin rights to"
					}
				},
				"required": ["targetUserId"]
			},
			"GroupMovieResponseDto": {
				"type": "object",
				"properties": {
					"id": { "type": "number" },
					"groupId": { "type": "number" },
					"source": { "type": "string", "enum": ["provider", "custom"] },
					"movieId": { "type": "number", "nullable": true },
					"title": { "type": "string" },
					"posterPath": { "type": "string", "nullable": true },
					"overview": { "type": "string", "nullable": true },
					"releaseYear": { "type": "number", "nullable": true },
					"runtime": { "type": "number", "nullable": true },
					"rating": { "type": "string", "nullable": true },
					"addedBy": { "type": "number" },
					"status": { "type": "string", "enum": ["tracking", "planned", "watched"] },
					"plannedDate": { "format": "date-time", "type": "string", "nullable": true },
					"watchedDate": { "format": "date-time", "type": "string", "nullable": true },
					"createdAt": { "format": "date-time", "type": "string" },
					"updatedAt": { "format": "date-time", "type": "string" },
					"currentUserRole": { "type": "string", "enum": ["admin", "moderator", "member"] }
				},
				"required": [
					"id",
					"groupId",
					"source",
					"movieId",
					"title",
					"posterPath",
					"overview",
					"releaseYear",
					"runtime",
					"rating",
					"addedBy",
					"status",
					"plannedDate",
					"watchedDate",
					"createdAt",
					"updatedAt"
				]
			},
			"SearchInGroupResponseDto": {
				"type": "object",
				"properties": {
					"provider": { "$ref": "#/components/schemas/ProviderSearchResult" },
					"currentGroup": {
						"type": "array",
						"items": { "$ref": "#/components/schemas/GroupMovieResponseDto" }
					}
				},
				"required": ["provider", "currentGroup"]
			},
			"AddMovieDto": {
				"type": "object",
				"properties": {
					"imdbId": {
						"type": "string",
						"description": "IMDb ID (universal, takes priority)",
						"example": "tt0133093"
					},
					"externalId": {
						"type": "string",
						"description": "Provider external ID",
						"example": "301"
					}
				}
			},
			"CreateCustomMovieDto": {
				"type": "object",
				"properties": {
					"title": { "type": "string", "description": "Movie title" },
					"posterPath": { "type": "string", "description": "Poster path" },
					"overview": { "type": "string", "description": "Movie overview" },
					"releaseYear": { "type": "number", "description": "Release year" },
					"runtime": { "type": "number", "description": "Runtime in minutes" },
					"status": {
						"type": "string",
						"description": "Movie status",
						"enum": ["tracking", "planned", "watched"],
						"default": "tracking"
					},
					"plannedDate": {
						"type": "string",
						"description": "Planned watch date",
						"example": "2024-12-31T20:00:00Z"
					},
					"watchedDate": {
						"type": "string",
						"description": "Watched date",
						"example": "2024-12-25T20:00:00Z"
					}
				},
				"required": ["title"]
			},
			"GroupMovieUpdateDto": {
				"type": "object",
				"properties": {
					"status": {
						"type": "string",
						"description": "Movie status in group",
						"enum": ["tracking", "planned", "watched"]
					},
					"plannedDate": {
						"type": "string",
						"description": "Planned watch date",
						"example": "2024-12-31T20:00:00Z"
					},
					"watchedDate": {
						"type": "string",
						"description": "Watched date",
						"example": "2024-12-25T20:00:00Z"
					},
					"title": { "type": "string", "description": "Movie title" },
					"posterPath": { "type": "string", "description": "Poster path" },
					"overview": { "type": "string", "description": "Movie overview" },
					"releaseYear": { "type": "number", "description": "Release year" },
					"runtime": { "type": "number", "description": "Runtime in minutes" }
				}
			}
		}
	},
	"security": [{ "access-token": [] }]
}
