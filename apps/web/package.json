{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "web",
	"private": true,
	"version": "0.14.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"check": "eslint . && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"fix": "eslint . --fix && prettier --write .",
		"check:types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"types:generate": "orval",
		"types:fetch": "../../scripts/generate-types.sh"
	},
	"dependencies": {
		"@lucide/svelte": "catalog:",
		"@repo/ui": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@eslint/compat": "catalog:",
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"orval": "^8.6.2",
		"prettier": "catalog:",
		"prettier-plugin-svelte": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-devtools-json": "^1.0.0"
	}
}
