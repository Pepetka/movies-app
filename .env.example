# Database
POSTGRES_USER=movies
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=movies_db
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgres://movies:change_me_in_production@localhost:5432/movies_db

# Application
NODE_ENV=production
PORT=8080
# WEB_URL can be comma-separated for multiple CORS origins
WEB_URL=http://localhost:5173,http://192.168.X.X:5173
API_URL=https://yourdomain.com
COOKIE_SECRET=change_me_in_production_32_chars_min

# JWT Configuration
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12

# Kinopoisk API Configuration
KINOPOISK_API_KEY=your_kinopoisk_api_key_here
KINOPOISK_BASE_URL=https://kinopoiskapi.com

# OAuth — Google (optional)
GOOGLE_CLIENT_ID=test
GOOGLE_CLIENT_SECRET=test-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/google/callback

# SSL (nginx/certbot)
DOMAIN=yourdomain.com
CERTBOT_EMAIL=your@email.com
